# EX-AI-MCP-Server  .env.example (minimal, matches .env)
# Purpose: Keep this example small and user-friendly. Backend hides complexity.
# Note: Do NOT place real secrets here. Leave keys blank. Use .env for actual values.
# Base URLs: use Moonshot (Kimi) OpenAI-compatible and ZhipuAI GLM endpoints.

# ---------- Core Server ----------
DEFAULT_MODEL=glm-4.5-flash  # default chat model
ROUTER_ENABLED=true          # enable router service

# WebSocket daemon/shim
EXAI_WS_CALL_TIMEOUT=180     # per-call timeout (seconds)
EXAI_WS_COMPAT_TEXT=true     # include top-level 'text' in responses for UI

# ---------- Unified Web Search Controls ----------
# Simple, provider-agnostic toggles; backend maps to provider-native tools
EX_WEB_ENABLED=true
EX_WEB_PROVIDERS=glm,kimi
SEARCH_BACKEND=duckduckgo

# ---------- Intelligent Routing (GLM Flash Manager) ----------
ENABLE_INTELLIGENT_ROUTING=true
ROUTING_STRATEGY=hybrid_intelligent
ROUTING_SUMMARY_MAX_TOKENS=500
ROUTING_COST_THRESHOLD=0.10
ROUTING_PERFORMANCE_THRESHOLD=5.0
GLM_COMPLEX_MODEL=glm-4.5
KIMI_FILE_MODEL=kimi-k2-0905-preview
GLM_FLASH_ROUTING_MODEL=glm-4.5-flash
GLM_FLASH_ROUTING_MAX_TOKENS=500
ROUTING_CACHE_TTL=300

# ---------- Provider Configuration ----------
# Kimi (Moonshot)
KIMI_API_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=

# GLM (ZhipuAI)
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=

# ---------- MCP Identity / Pathing ----------
MCP_SERVER_ID=
MCP_SERVER_NAME=
EX_ALLOW_EXTERNAL_PATHS=true  # allow file access; restrict at OS level as needed

# ---------- GitHub MCP (enhanced gh-mcp) ----------
GH_HOST=github.com
GH_MCP_DEFAULT_REPO_PATH=
GH_MCP_REPO_EXAI=
GH_MCP_REPO_PERSONAL_AI_AGENT=
GH_MCP_REPO_GH_CLI=
GH_SSH_KEY=
GH_SSH_EMAIL=
GH_TOKEN=

# ---------- Supabase Bridge ----------
BRIDGE_SUPABASE_URL=
BRIDGE_SUPABASE_KEY=
BRIDGE_BUCKET_EXAI_WS_FILES=
BRIDGE_BUCKET_EXAI_MODEL_FILES=
BRIDGE_BUCKET_EXAI_ARTIFACTS=
BRIDGE_BUCKET_EXAI_LOGS=

# ---------- Supabase Credentials ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_PASSWORD=
SUPABASE_STORAGE_S3_COMPAT_URL=
SUPABASE_STORAGE_S3_COMPAT_REGION=
SUPABASE_STORAGE_S3_COMPAT_ACCESS_KEY=
SUPABASE_STORAGE_S3_COMPAT_SECRET_KEY=

# ---------- Notes ----------
# - This example lists only variables actually used by .env to keep things simple.
# - Advanced/experimental flags were intentionally omitted. The backend auto-configures
#   provider-native browsing and capabilities when EX_WEB_* is set.
# - For any new variables added in the future, update both .env and this file.
